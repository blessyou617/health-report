/* components/lifestyle-advice/lifestyle-advice.wxss */

.advice-card {
  background: linear-gradient(135deg, #f6ffed 0%, #d9f7be 100%);
  border-radius: 24rpx;
  margin: 24rpx;
  overflow: hidden;
  border: 2rpx solid #b7eb8f;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid rgba(183, 235, 143, 0.5);
}

.header-left {
  display: flex;
  align-items: center;
}

.icon-wrapper {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.icon-wrapper.advice {
  background: #fff;
}

.icon {
  width: 36rpx;
  height: 36rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #389e0d;
}

.card-body {
  padding: 32rpx;
}

.advice-content {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
}

.advice-text {
  font-size: 34rpx;
  line-height: 56rpx;
  color: #389e0d;
  font-weight: 500;
}

.card-actions {
  display: flex;
  padding: 0 24rpx 24rpx;
  gap: 20rpx;
}

.action-button {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.action-button.voice {
  background: #fff;
  border: 2rpx solid #389e0d;
}

.action-button.share {
  background: #fff;
  border: 2rpx solid #1890ff;
}

.action-button:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.action-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.action-text {
  font-size: 30rpx;
  font-weight: 600;
}

.action-button.voice .action-text {
  color: #389e0d;
}

.action-button.share .action-text {
  color: #1890ff;
}

.card-footer {
  padding: 24rpx;
  border-top: 2rpx solid rgba(183, 235, 143, 0.5);
}

.question-button {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #389e0d;
  border-radius: 50rpx;
  padding: 28rpx;
}

.question-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 16rpx;
}

.question-text {
  font-size: 34rpx;
  color: #fff;
  font-weight: bold;
}
