/* chat.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f7fa;
}

.header {
  background: #fff;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.remaining {
  font-size: 24rpx;
  color: #4A90E2;
}

.chat-area {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}

.messages {
  display: flex;
  flex-direction: column;
}

.message {
  display: flex;
  margin-bottom: 30rpx;
  align-items: flex-start;
}

.message.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.message.user .avatar {
  margin-left: 20rpx;
}

.message.ai .avatar {
  margin-right: 20rpx;
}

.bubble {
  max-width: 70%;
  padding: 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.message.ai .bubble {
  background: #fff;
  color: #333;
}

.message.user .bubble {
  background: #4A90E2;
  color: #fff;
}

.suggestion {
  display: block;
  font-size: 26rpx;
  color: #4A90E2;
  margin-top: 12rpx;
}

.message.user .suggestion {
  color: rgba(255, 255, 255, 0.9);
}

.input-area {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.input {
  flex: 1;
  height: 80rpx;
  background: #f5f7fa;
  border-radius: 40rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 80rpx;
  height: 80rpx;
  background: #4A90E2;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
  padding: 0;
}

.send-btn[disabled] {
  background: #ccc;
}

.send-icon {
  width: 40rpx;
  height: 40rpx;
}

.no-questions {
  background: #fff;
  padding: 60rpx;
  text-align: center;
}

.no-questions text {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 30rpx;
}

.back-btn {
  background: #4A90E2;
  color: #fff;
  border-radius: 40rpx;
  width: 300rpx;
}
