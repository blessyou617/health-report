<!--index.wxml-->
<view class="container">
  <view class="header">
    <image class="logo" src="/images/logo.png" mode="aspectFit"></image>
    <text class="title">AI 体检报告分析</text>
    <text class="subtitle">智能解读您的健康报告</text>
  </view>

  <view class="features">
    <view class="feature-item">
      <image class="feature-icon" src="/images/upload.png"></image>
      <text class="feature-text">上传体检报告</text>
    </view>
    <view class="feature-item">
      <image class="feature-icon" src="/images/ai.png"></image>
      <text class="feature-text">AI 智能分析</text>
    </view>
    <view class="feature-item">
      <image class="feature-icon" src="/images/voice.png"></image>
      <text class="feature-text">语音播报</text>
    </view>
    <view class="feature-item">
      <image class="feature-icon" src="/images/chat.png"></image>
      <text class="feature-text">在线追问</text>
    </view>
  </view>

  <view class="action-area">
    <button class="upload-btn" bindtap="goToUpload">
      <image class="btn-icon" src="/images/camera.png"></image>
      <text>上传体检报告</text>
    </button>
  </view>

  <view class="recent-reports" wx:if="{{recentReports.length > 0}}">
    <text class="section-title">最近报告</text>
    <view class="report-list">
      <view 
        class="report-item" 
        wx:for="{{recentReports}}" 
        wx:key="id"
        bindtap="viewReport"
        data-id="{{item.id}}"
      >
        <view class="report-info">
          <text class="report-date">{{item.date}}</text>
          <text class="report-status {{item.status}}">{{item.statusText}}</text>
        </view>
        <text class="arrow">></text>
      </view>
    </view>
  </view>
</view>
