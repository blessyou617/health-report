/* index.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #4A90E2 0%, #67B8DE 100%);
  padding: 40rpx;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.features {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  margin: 60rpx 0;
}

.feature-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 16rpx;
}

.feature-text {
  font-size: 24rpx;
  color: #fff;
  text-align: center;
}

.action-area {
  margin: 60rpx 0;
}

.upload-btn {
  width: 100%;
  height: 120rpx;
  background: #fff;
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #4A90E2;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.15);
}

.upload-btn:active {
  transform: scale(0.98);
}

.btn-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

.recent-reports {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-top: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.report-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.report-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.report-item:last-child {
  border-bottom: none;
}

.report-info {
  display: flex;
  flex-direction: column;
}

.report-date {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.report-status {
  font-size: 24rpx;
  color: #999;
}

.report-status.completed {
  color: #52c41a;
}

.report-status.processing {
  color: #faad14;
}

.arrow {
  color: #ccc;
  font-size: 32rpx;
}
