/* upload.wxss */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
}

.upload-area {
  background: #fff;
  border-radius: 24rpx;
  padding: 80rpx 40rpx;
  margin-bottom: 40rpx;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.upload-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
}

.upload-text {
  font-size: 32rpx;
  color: #4A90E2;
  margin-bottom: 16rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: #ccc;
}

.file-preview {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #f0f7ff;
  border-radius: 16rpx;
}

.file-icon {
  width: 80rpx;
  height: 80rpx;
  margin-right: 24rpx;
}

.file-info {
  flex: 1;
}

.file-name {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.file-size {
  font-size: 24rpx;
  color: #999;
}

.remove-btn {
  width: 48rpx;
  height: 48rpx;
  background: #ff4d4f;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-btn text {
  color: #fff;
  font-size: 28rpx;
}

.tips {
  background: #fff9e6;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.tips-title {
  font-size: 28rpx;
  color: #fa8c16;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.tips-item {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 8rpx;
}

.action-area {
  margin-top: 40rpx;
}

.next-btn {
  width: 100%;
  height: 100rpx;
  background: #4A90E2;
  border-radius: 50rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.next-btn[disabled] {
  background: #ccc;
}
