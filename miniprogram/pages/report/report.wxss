/* report.wxss */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 30rpx;
  padding-bottom: 160rpx;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.date {
  font-size: 26rpx;
  color: #999;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.card-content {
  margin-bottom: 20rpx;
}

.summary-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
}

.voice-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0f7ff;
  border-radius: 30rpx;
  padding: 16rpx 30rpx;
  font-size: 26rpx;
  color: #4A90E2;
  width: auto;
  min-width: 200rpx;
}

.voice-btn.playing {
  background: #fff0f0;
  color: #ff4d4f;
}

.voice-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.item-list {
  display: flex;
  flex-direction: column;
}

.item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.item-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-top: 16rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.item.abnormal .item-dot {
  background: #ff4d4f;
}

.item.normal .item-dot {
  background: #52c41a;
}

.item-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.advice-card {
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
}

.advice-text {
  font-size: 30rpx;
  color: #2e7d32;
  line-height: 1.8;
}

.action-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.qa-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #4A90E2 0%, #67B8DE 100%);
  border-radius: 50rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  height: 100rpx;
}

.qa-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}
